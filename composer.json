{
    "name": "krunalvat/location-dropdowns",
    "description": "A Laravel package for Country, State, and City location dropdowns.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Krunal Vatvani",
            "email": "krunal@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Krunalvatvani\\LocationDropdowns\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Krunalvatvani\\LocationDropdowns\\LocationServiceProvider"
            ]
        }
    }
}
